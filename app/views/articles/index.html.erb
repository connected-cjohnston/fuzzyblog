<h1>Articles</h1>
<%= link_to 'New Article', new_article_path %>

<% @articles.each do |article| %>
  <div class='article_block'>
    <h2>
      <%= link_to article.title, article %>
    </h2>
    <% if article.article_image.persisted?%>
      <%= image_tag(article.article_image.variant(resize_to_limit: [700, 700])) %>
    <% end %>
    <p>
      <%= raw @markdown.render(article.body) %>
    </p>
  <div>
<% end %>
