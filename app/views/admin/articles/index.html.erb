<h1>Articles</h1>
<%= link_to 'New Article', new_admin_article_path %>

<table>
  <tr>
    <td>
      Article Title
    </td>
    <td>Author</td>
    <td>
    </td>
    <td>
    </td>
  </tr>
  <% @articles.each do |article| %>
    <tr>
      <td>
        <%= article.title %>
      </td>
      <td>
        <%= article.user.name %>
      </td>
      <td>
        <%= link_to 'Edit', edit_admin_article_path(article.id) %>
      </td>
      <td>
        <%= link_to 'Delete', admin_article_path(article), method: :delete, data: { confirm: "Are you sure?" } %>
      </td>
    </tr>
  <% end %>
</table>

